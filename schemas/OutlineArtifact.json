{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OutlineArtifact",
  "type": "object",
  "required": ["thesis", "structure", "risks", "editorial_intent"],
  "properties": {
    "thesis": { "type": "string", "minLength": 10 },
    "structure": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["section", "intent"],
        "properties": {
          "section": { "type": "string" },
          "intent": { "type": "string" },
          "evidence_needed": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "risks": { "type": "array", "items": { "type": "string" } },
    "editorial_intent": { "type": "string", "minLength": 10 }
  }
}
