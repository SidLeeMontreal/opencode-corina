{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RubricReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "rubric_id",
    "rubric_name",
    "total_score",
    "max_total_score",
    "dimensions",
    "strongest_dimensions",
    "weakest_dimensions",
    "overall_assessment",
    "assumptions"
  ],
  "properties": {
    "status": { "type": "string", "enum": ["ok", "no_input", "degraded"] },
    "rubric_id": { "type": "string" },
    "rubric_name": { "type": "string" },
    "voice_profile_hint": { "type": ["string", "null"] },
    "total_score": { "type": "number", "minimum": 0 },
    "max_total_score": { "type": "number", "minimum": 1 },
    "dimensions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "score", "max_score", "rationale", "strengths", "weaknesses", "fix_directions"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "score": { "type": "number", "minimum": 0 },
          "max_score": { "type": "number", "minimum": 1 },
          "rationale": { "type": "string" },
          "strengths": { "type": "array", "items": { "type": "string" } },
          "weaknesses": { "type": "array", "items": { "type": "string" } },
          "fix_directions": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "strongest_dimensions": { "type": "array", "items": { "type": "string" } },
    "weakest_dimensions": { "type": "array", "items": { "type": "string" } },
    "overall_assessment": { "type": "string" },
    "assumptions": { "type": "array", "items": { "type": "string" } }
  }
}
