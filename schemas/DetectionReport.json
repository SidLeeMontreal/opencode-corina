{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DetectionReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "overall_score",
    "confidence",
    "verdict",
    "summary",
    "input",
    "patterns_found",
    "pattern_counts",
    "top_signals",
    "layer_1_scan",
    "layer_2_analysis",
    "assumptions"
  ],
  "properties": {
    "overall_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
    "verdict": { "type": "string", "enum": ["clean", "probably_human", "possibly_ai", "likely_ai"] },
    "summary": { "type": "string", "minLength": 1 },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_type", "source_path", "character_count", "word_count", "paragraph_count", "sentence_count"],
      "properties": {
        "source_type": { "type": "string", "enum": ["text", "file"] },
        "source_path": { "type": ["string", "null"] },
        "character_count": { "type": "integer", "minimum": 0 },
        "word_count": { "type": "integer", "minimum": 0 },
        "paragraph_count": { "type": "integer", "minimum": 0 },
        "sentence_count": { "type": "integer", "minimum": 0 }
      }
    },
    "patterns_found": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "pattern_id",
          "pattern_name",
          "category",
          "severity",
          "confidence",
          "matched_text",
          "normalized_match",
          "location_hint",
          "char_start",
          "char_end",
          "rule_source",
          "explanation",
          "fix_suggestion",
          "context_before",
          "context_after"
        ],
        "properties": {
          "pattern_id": { "type": "string", "minLength": 1 },
          "pattern_name": { "type": "string", "minLength": 1 },
          "category": { "type": "string", "enum": ["content", "language", "style", "communication", "filler"] },
          "severity": { "type": "string", "enum": ["high", "medium", "low"] },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
          "matched_text": { "type": "string", "minLength": 1 },
          "normalized_match": { "type": "string", "minLength": 1 },
          "location_hint": { "type": "string", "minLength": 1 },
          "char_start": { "type": "integer", "minimum": 0 },
          "char_end": { "type": "integer", "minimum": 0 },
          "rule_source": { "type": "string", "enum": ["layer_1", "layer_2"] },
          "explanation": { "type": "string", "minLength": 1 },
          "fix_suggestion": { "type": "string", "minLength": 1 },
          "context_before": { "type": "string" },
          "context_after": { "type": "string" }
        }
      }
    },
    "pattern_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["by_pattern", "by_category", "by_severity"],
      "properties": {
        "by_pattern": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "by_category": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "by_severity": {
          "type": "object",
          "additionalProperties": false,
          "required": ["high", "medium", "low"],
          "properties": {
            "high": { "type": "integer", "minimum": 0 },
            "medium": { "type": "integer", "minimum": 0 },
            "low": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "top_signals": { "type": "array", "items": { "type": "string" } },
    "layer_1_scan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score", "deep_recommended", "rules_triggered", "ambiguous_patterns", "notes"],
      "properties": {
        "score": { "type": "number", "minimum": 0, "maximum": 1 },
        "deep_recommended": { "type": "boolean" },
        "rules_triggered": { "type": "array", "items": { "type": "string" } },
        "ambiguous_patterns": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "layer_2_analysis": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["ran", "confirmed_patterns", "dismissed_patterns", "reasoning_notes", "score_adjustment", "additional_findings"],
          "properties": {
            "ran": { "type": "boolean" },
            "score_adjustment": { "type": "number", "minimum": -0.5, "maximum": 0.5 },
            "confirmed_patterns": { "type": "array", "items": { "type": "string" } },
            "dismissed_patterns": { "type": "array", "items": { "type": "string" } },
            "additional_findings": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["pattern_id", "matched_text", "explanation", "severity", "confidence", "fix_suggestion"],
                "properties": {
                  "pattern_id": { "type": "string" },
                  "matched_text": { "type": "string" },
                  "location_hint": { "type": "string" },
                  "explanation": { "type": "string" },
                  "severity": { "type": "string", "enum": ["high", "medium", "low"] },
                  "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
                  "fix_suggestion": { "type": "string" }
                }
              }
            },
            "reasoning_notes": { "type": "array", "items": { "type": "string" } }
          }
        }
      ]
    },
    "assumptions": { "type": "array", "items": { "type": "string" } }
  }
}
