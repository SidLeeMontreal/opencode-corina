{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CritiqueArtifact",
  "type": "object",
  "required": ["pass", "overall_score", "dimensions", "revision_instructions", "fatal_issues"],
  "properties": {
    "pass": { "type": "boolean" },
    "overall_score": { "type": "number", "minimum": 0, "maximum": 30 },
    "dimensions": {
      "type": "object",
      "required": ["ai_patterns", "tone", "precision", "evidence", "rhythm"],
      "properties": {
        "ai_patterns": {
          "type": "object",
          "required": ["score", "issues"],
          "properties": {
            "score": { "type": "number", "minimum": 0, "maximum": 6 },
            "issues": { "type": "array", "items": { "type": "string" } }
          }
        },
        "tone": {
          "type": "object",
          "required": ["score", "issues"],
          "properties": {
            "score": { "type": "number", "minimum": 0, "maximum": 6 },
            "issues": { "type": "array", "items": { "type": "string" } }
          }
        },
        "precision": {
          "type": "object",
          "required": ["score", "issues"],
          "properties": {
            "score": { "type": "number", "minimum": 0, "maximum": 6 },
            "issues": { "type": "array", "items": { "type": "string" } }
          }
        },
        "evidence": {
          "type": "object",
          "required": ["score", "issues"],
          "properties": {
            "score": { "type": "number", "minimum": 0, "maximum": 6 },
            "issues": { "type": "array", "items": { "type": "string" } }
          }
        },
        "rhythm": {
          "type": "object",
          "required": ["score", "issues"],
          "properties": {
            "score": { "type": "number", "minimum": 0, "maximum": 6 },
            "issues": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "revision_instructions": { "type": "array", "items": { "type": "string" } },
    "fatal_issues": { "type": "array", "items": { "type": "string" } },
    "findings": { "type": "array", "items": { "type": "object" } },
    "module_status": { "type": "object" },
    "degraded": { "type": "boolean" }
  }
}
